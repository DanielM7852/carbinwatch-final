# ============================================================
# CarbinWatcher — example environment variables
# Copy to .env (local dev) or .env.local and fill in real values.
# NEVER commit real secrets.
# ============================================================

# ----- AWS -----
AWS_REGION=us-west-2
# Prefer ~/.aws/credentials or IAM role. Only set these for local dev.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ----- AWS IoT Core -----
AWS_IOT_ENDPOINT=xxxxxxxx-ats.iot.us-west-2.amazonaws.com
AWS_IOT_THING_NAME=carbinwatcher-kitchen-01
AWS_IOT_CERT_PATH=./certs/device.pem.crt
AWS_IOT_KEY_PATH=./certs/private.pem.key
AWS_IOT_ROOT_CA_PATH=./certs/AmazonRootCA1.pem

# ----- AWS services -----
S3_BUCKET=carbinwatcher-raw
FIREHOSE_STREAM_NAME=carbinwatcher-ingest
DYNAMODB_TABLE=carbinwatcher-state
SES_SENDER_EMAIL=alerts@carbinwatcher.example
SNS_ALERT_TOPIC_ARN=arn:aws:sns:us-west-2:000000000000:carbinwatcher-alerts

# ----- Databricks -----
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_CATALOG=carbinwatcher
DATABRICKS_SCHEMA=gold

# ----- Gemini -----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ----- Backend API -----
API_PORT=8000

# ----- Frontend (Next.js) -----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=CarbinWatcher
