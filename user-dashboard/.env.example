# Copy to `.env.local` and fill in. `.env.local` is gitignored.

AWS_REGION=us-east-2
DYNAMODB_TABLE_NAME=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: DynamoDB volume attribute if auto-detection misses it
# DYNAMODB_VOLUME_ATTR=

# Optional: use AWS CLI profile instead of keys above (omit the two key lines when true)
# AWS_USE_CLI_CREDENTIALS=true

# Live webcam: /api/webcam proxies with ngrok skip header (free ngrok HTML interstitial breaks raw img tags).
# Point at the real MJPEG/JPEG path (often /stream or /capture), not always the tunnel root.
# NEXT_PUBLIC_WEBCAM_URL=https://YOUR_SUBDOMAIN.ngrok-free.dev/stream
# Optional: comma-separated extra hostnames if not using ngrok (see app/api/webcam/route.ts)
# WEBCAM_UPSTREAM_ALLOW_HOST=
